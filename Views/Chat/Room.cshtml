@model IEnumerable<GoldBranchAI.Models.ChatMessage>
@{
    var targetUser = ViewBag.TargetUser as GoldBranchAI.Models.AppUser;
    var targetGroup = ViewBag.TargetGroup as GoldBranchAI.Models.ChatGroup;
    bool isGroup = ViewBag.IsGroup ?? false;
    int currentUserId = ViewBag.CurrentUserId;
    string userRole = ViewBag.UserRole as string;
    
    // Header Info
    string title = isGroup ? targetGroup.GroupName : targetUser.FullName;
    string subtitle = isGroup ? $"{targetGroup.Members.Count} Üye" : "SISTEME BAGLI";
    string iconClass = isGroup ? "fa-users text-warning" : "fa-user-astronaut text-info";
    string iconBg = isGroup ? "rgba(251, 191, 36, 0.1)" : "rgba(34, 211, 238, 0.1)";

    Layout = null;
}

<!DOCTYPE html>
<html data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { background: #0d1117; margin:0; padding:0; overflow:hidden; font-family: 'Inter', sans-serif; color: #c9d1d9; }
        .chat-wrapper { height: 100vh; display: flex; flex-direction: column; }
        .chat-header { flex-shrink: 0; background: rgba(22, 27, 34, 0.95); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 15px 20px; display:flex; align-items:center; }
        .chat-body { flex-grow: 1; overflow-y: auto; padding: 25px; background-image: radial-gradient(rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 30px 30px; }
        .chat-footer { flex-shrink: 0; background: rgba(22, 27, 34, 0.95); border-top: 1px solid rgba(255,255,255,0.05); padding: 15px 20px; }
        
        .chat-body::-webkit-scrollbar { width: 5px; }
        .chat-body::-webkit-scrollbar-track { background: transparent; }
        .chat-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }

        .msg-bubble { 
            max-width: 70%; 
            padding: 12px 16px; 
            border-radius: 20px; 
            position: relative; 
            margin-bottom: 4px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            word-wrap: break-word;
        }
        .msg-mine { background: #0dcaf0; color: #000; border-bottom-right-radius: 4px; border: 1px solid rgba(0,0,0,0.1); }
        .msg-theirs { background: #21262d; color: #c9d1d9; border-bottom-left-radius: 4px; border: 1px solid rgba(255,255,255,0.05); }
        
        .sender-name { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; display: block; opacity: 0.8; }
        .msg-time { font-size: 0.6rem; margin-top: 4px; display: block; text-align: right; opacity: 0.7; }

        .form-control:focus { box-shadow: none !important; border-color: #0dcaf0 !important; }
    </style>
</head>
<body>
    <div class="chat-wrapper">
        <!-- HEADER -->
        <div class="chat-header">
            <div style="width:44px;height:44px;border-radius:12px;background:@iconBg;display:flex;align-items:center;justify-content:center;margin-right:15px;border:1px solid rgba(255,255,255,0.05);">
                <i class="fa-solid @iconClass fs-5"></i>
            </div>
            <div>
                <h6 class="mb-0 fw-bold text-light">@title</h6>
                <small class="fw-bold @(isGroup ? "text-warning" : "text-success")" style="font-size:0.65rem; letter-spacing:0.5px;">
                    <i class="fa-solid fa-circle me-1" style="font-size:0.4rem;"></i> @subtitle
                </small>
            </div>
            @if (userRole == "Admin" && !isGroup)
            {
                <div class="ms-auto"><span class="badge bg-danger rounded-pill px-3 py-2" style="font-size:0.6rem;"><i class="fa-solid fa-satellite-dish me-1"></i> IZLEME MODU</span></div>
            }
        </div>
        
        <!-- BODY -->
        <div class="chat-body" id="chatBox">
            @foreach (var msg in Model)
            {
                bool isMine = msg.SenderId == currentUserId;
                string alignClass = isMine ? "justify-content-end" : "justify-content-start";
                
                <div class="d-flex @alignClass mb-3">
                    <div class="msg-bubble @(isMine ? "msg-mine" : "msg-theirs")">
                        @if (!isMine)
                        {
                            <span class="sender-name">@msg.Sender?.FullName</span>
                        }
                        <div class="msg-text">@msg.MessageText</div>
                        <span class="msg-time">@msg.SentAt.ToString("HH:mm") @(isMine ? "✓✓" : "")</span>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-50">
                    <i class="fa-solid fa-shield-halved fa-4x mb-3"></i>
                    <p class="small">Sohbet Uctan Uca Sifrelenmistir.</p>
                </div>
            }
        </div>
        
        <!-- FOOTER -->
        @if (userRole != "Admin" || (isGroup == false && targetUser?.Role == "Proje Sefi"))
        {
            <div class="chat-footer">
                <form id="chatForm" onsubmit="submitMessage(event)" class="d-flex gap-2">
                    <input type="hidden" id="receiverId" value="@(targetUser?.Id)" />
                    <input type="hidden" id="groupId" value="@(targetGroup?.Id)" />
                    <input type="text" id="messageText" class="form-control bg-dark text-light border-0 py-3 px-4 shadow-none" style="border-radius: 25px; background: #161b22 !important;" placeholder="Mesajinizi yazin..." required autocomplete="off" />
                    <button type="submit" class="btn btn-info rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; min-width: 50px; transition:0.2s;">
                        <i class="fa-solid fa-paper-plane text-dark fs-5"></i>
                    </button>
                </form>
            </div>
        }
    </div>

    <script>
        // Scroll to bottom on load
        var chatBox = document.getElementById("chatBox");
        if(chatBox) chatBox.scrollTop = chatBox.scrollHeight;

        function submitMessage(e) {
            e.preventDefault();
            const btn = document.querySelector('button[type="submit"]');
            const receiverId = document.getElementById('receiverId').value;
            const groupId = document.getElementById('groupId').value;
            const msgInput = document.getElementById('messageText');
            const msg = msgInput.value;
            
            if(!msg.trim()) return;

            msgInput.disabled = true;
            btn.disabled = true;

            let body = 'messageText=' + encodeURIComponent(msg);
            if(receiverId) body += '&receiverId=' + receiverId;
            if(groupId) body += '&groupId=' + groupId;

            fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body
            }).then(() => {
                window.location.reload();
            }).catch(() => {
                window.location.reload();
            });
        }
    </script>
</body>
</html>