@model GoldBranchAI.Models.TodoTask
@{
    ViewData["Title"] = "Gorev Subay Kaydi: " + Model.Title;
    var currentUserRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
    
    // Status badges logic
    string statusBadge = "bg-primary";
    string statusIcon = "fa-circle-info";
    if (Model.Status == "Devam Ediyor") { statusBadge = "bg-primary"; statusIcon = "fa-spinner fa-spin"; }
    else if (Model.Status == "Onay Bekliyor") { statusBadge = "bg-info text-dark"; statusIcon = "fa-check"; }
    else if (Model.Status == "Revize") { statusBadge = "bg-warning text-dark"; statusIcon = "fa-rotate-left"; }
    else if (Model.Status == "Tamamlandi") { statusBadge = "bg-success"; statusIcon = "fa-check-double"; }
}

<div class="row justify-content-center mt-4 mb-5 fade-in-up">
    <div class="col-lg-9">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill pe-4 ps-3 shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Radara Don
            </a>
            
            @if (currentUserRole == "Proje Sefi")
            {
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-info fw-bold rounded-pill text-dark px-3 me-2 shadow-sm">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Duzenle
                    </a>
                    <button type="button" class="btn btn-danger fw-bold rounded-pill px-3 shadow-sm" onclick="document.getElementById('deleteOverlay').classList.add('active')">
                        <i class="fa-solid fa-trash me-1"></i> Iptal Et (Sil)
                    </button>
                </div>
            }
        </div>

        <div class="card bg-dark border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
            <div class="card-header border-0 pt-4 pb-0 bg-transparent px-4 px-md-5">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge @statusBadge rounded-pill px-3 py-2" style="font-size:0.85rem; letter-spacing:1px; box-shadow:0 0 15px currentColor;">
                        <i class="fa-solid @statusIcon me-1"></i> @Model.Status.ToUpper()
                    </span>
                    <span class="text-muted small fw-bold" style="font-family:'JetBrains Mono',monospace;">#TSK-@Model.Id.ToString("0000")</span>
                </div>
                <h2 class="fw-bold mb-3 text-light" style="font-size: 2.2rem;">@Model.Title</h2>
            </div>
            
            <div class="card-body px-4 px-md-5 py-4">
                
                <div class="row mb-4 g-4 fade-in-up" style="animation-delay: 0.1s;">
                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08);">
                            <span class="text-secondary small fw-bold text-uppercase d-block mb-1"><i class="fa-regular fa-calendar-check text-warning me-1"></i> Son Teslim</span>
                            <span class="text-light fw-bold">@Model.DueDate.ToString("dd MMMM yyyy HH:mm")</span>
                            @{ var r = Model.DueDate - DateTime.Now; }
                            @if (r.TotalHours < 0 && Model.Status != "Tamamlandi") { <div class="text-danger small mt-1"><i class="fa-solid fa-triangle-exclamation"></i> Gecikti</div> }
                            else if (r.TotalHours > 0 && r.TotalHours < 24) { <div class="text-warning small mt-1 pulse-danger"><i class="fa-regular fa-clock"></i> @Math.Round(r.TotalHours) saat kaldi</div> }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08);">
                            <span class="text-secondary small fw-bold text-uppercase d-block mb-1"><i class="fa-solid fa-user-astronaut text-info me-1"></i> Atanan Gelistirici</span>
                            <span class="text-light fw-bold">@(Model.AppUser?.FullName ?? "Bilinmiyor")</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08);">
                            <span class="text-secondary small fw-bold text-uppercase d-block mb-1"><i class="fa-solid fa-hourglass-start text-success me-1"></i> Tahmini Sure</span>
                            <span class="text-light fw-bold">@Model.EstimatedTimeHours Saat</span>
                        </div>
                    </div>
                </div>

                <div class="mb-5 fade-in-up" style="animation-delay: 0.2s;">
                    <h5 class="text-light border-bottom border-secondary pb-2 mb-3"><i class="fa-solid fa-align-left text-warning me-2"></i> Gorev Detayi</h5>
                    <div class="text-muted" style="line-height: 1.7; font-size: 1.05rem; white-space: pre-wrap;">@Html.DisplayFor(m => m.Description)</div>
                </div>

                @if (!string.IsNullOrEmpty(Model.AttachedFilePath))
                {
                    <div class="mb-4 fade-in-up" style="animation-delay: 0.3s;">
                        <h5 class="text-light border-bottom border-secondary pb-2 mb-3"><i class="fa-solid fa-paperclip text-info me-2"></i> Ek Dosya</h5>
                        
                        @{
                            string ext = System.IO.Path.GetExtension(Model.AttachedFilePath).ToLower();
                            bool isImage = ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".webp";
                        }

                        @if (isImage)
                        {
                            <div class="mb-3 text-center rounded-4 overflow-hidden" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.5);">
                                <img src="@Model.AttachedFilePath" style="max-height: 400px; max-width: 100%; object-fit: contain;" />
                            </div>
                        }
                        
                        <a href="@Model.AttachedFilePath" target="_blank" class="btn btn-outline-info rounded-pill px-4">
                            <i class="fa-solid fa-cloud-arrow-down me-2"></i> Dosyayi Indir
                        </a>
                    </div>
                }

            </div>
            
            <div class="card-footer bg-transparent border-top border-secondary p-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="text-muted small"><i class="fa-regular fa-clock"></i> Kayit: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>

                <div>
                    @if (currentUserRole == "Gelistirici" && (Model.Status == "Devam Ediyor" || Model.Status == "Revize"))
                    {
                        <a asp-action="ChangeStatus" asp-route-id="@Model.Id" asp-route-newStatus="Onay Bekliyor" class="btn btn-info fw-bold rounded-pill text-dark px-4 shadow-lg">
                            <i class="fa-solid fa-paper-plane me-2"></i> Sefe Gonder (Is Bitti)
                        </a>
                    }
                    else if (currentUserRole == "Proje Sefi" && Model.Status == "Onay Bekliyor")
                    {
                        <a asp-action="ChangeStatus" asp-route-id="@Model.Id" asp-route-newStatus="Revize" class="btn btn-warning fw-bold rounded-pill text-dark px-4 me-2 shadow">
                            <i class="fa-solid fa-rotate-left me-2"></i> Revize İste
                        </a>
                        <a asp-action="ChangeStatus" asp-route-id="@Model.Id" asp-route-newStatus="Tamamlandi" class="btn btn-success fw-bold rounded-pill text-dark px-4 shadow">
                            <i class="fa-solid fa-check-double me-2"></i> Is Kabul (Tamamlandi)
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation - Custom Overlay -->
@if (currentUserRole == "Proje Sefi")
{
    <style>
        .delete-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 9990;
            background: rgba(0,0,0,0.6);
            justify-content: center;
            align-items: center;
        }
        .delete-overlay.active {
            display: flex;
        }
        .delete-panel {
            background: #161b22;
            border: 1px solid #dc3545;
            border-radius: 20px;
            width: 90%;
            max-width: 460px;
            box-shadow: 0 0 40px rgba(220,53,69,0.2), 0 25px 60px rgba(0,0,0,0.6);
            animation: deleteSlideIn 0.3s ease;
        }
        @@keyframes deleteSlideIn {
            from { opacity: 0; transform: translateY(-30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>
    <div class="delete-overlay" id="deleteOverlay">
        <div class="delete-panel">
            <div class="p-4 border-bottom text-danger" style="border-color: rgba(220,53,69,0.3) !important;">
                <h5 class="fw-bold mb-0"><i class="fa-solid fa-triangle-exclamation me-2"></i> Kritik Islem Uyarisi</h5>
            </div>
            <div class="py-4 text-center px-4">
                <i class="fa-solid fa-skull-crossbones fa-4x text-danger mb-3 opacity-75"></i>
                <p class="text-light mb-1 mt-2">Bu gorevi ve bagli tüm gecmisi silmek istediginizden emin misiniz?</p>
                <p class="text-muted small">Bu islem geri alinamayacaktir.</p>
            </div>
            <div class="d-flex justify-content-center gap-2 pb-4 px-4">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" onclick="document.getElementById('deleteOverlay').classList.remove('active')">Iptal</button>
                <form asp-controller="Task" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 shadow">
                        <i class="fa-solid fa-trash me-1"></i> Evet, Kalici Olarak Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
    <script>
        // ESC ile kapat
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                var el = document.getElementById('deleteOverlay');
                if (el) el.classList.remove('active');
            }
        });
        // Overlay'e tiklanirsa kapat
        var delOverlay = document.getElementById('deleteOverlay');
        if (delOverlay) {
            delOverlay.addEventListener('click', function(e) {
                if (e.target === this) this.classList.remove('active');
            });
        }
    </script>
}
