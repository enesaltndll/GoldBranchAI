@model GoldBranchAI.Models.AppUser
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sisteme Kayit Ol - GoldBranch AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #05070a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            top: 50%; right: -20%;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(34,211,238,0.1), transparent 70%);
            border-radius: 50%;
            animation: orbMoveR 14s ease-in-out infinite;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -10%; left: -15%;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(167,139,250,0.07), transparent 70%);
            border-radius: 50%;
            animation: orbMoveL 18s ease-in-out infinite;
            pointer-events: none;
        }

        @@keyframes orbMoveR {
            0%, 100% { transform: translate(0, -50%) scale(1); }
            50% { transform: translate(-80px, -40%) scale(1.15); }
        }

        @@keyframes orbMoveL {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(60px, -40px) scale(1.1); }
        }

        .register-card {
            background: rgba(13, 17, 23, 0.7);
            background: rgba(13, 17, 23, 0.98);
            border: 1px solid rgba(34, 211, 238, 0.12);
            border-radius: 24px;
            box-shadow:
                0 20px 60px rgba(0, 0, 0, 0.5),
                0 0 40px rgba(34, 211, 238, 0.05),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            animation: cardSlideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            opacity: 0;
            transform: translateY(40px) scale(0.95);
        }

        @@keyframes cardSlideUp {
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .register-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(34,211,238,0.6), rgba(167,139,250,0.4), transparent);
            animation: lineShimmer 3s ease-in-out infinite;
        }

        @@keyframes lineShimmer {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        .register-card::after {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(from 180deg, transparent, rgba(34,211,238,0.02), transparent 30%);
            animation: rotGlow 10s linear infinite;
            pointer-events: none;
        }

        @@keyframes rotGlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        .brand-text {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #22d3ee, #a78bfa, #22d3ee);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradShift 3s linear infinite;
        }

        @@keyframes gradShift {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        .brand-text i {
            -webkit-text-fill-color: #22d3ee;
            filter: drop-shadow(0 0 10px rgba(34,211,238,0.5));
        }

        .subtitle { color: #8b949e; font-size: 0.85rem; position: relative; z-index: 1; }

        .form-floating-custom { position: relative; z-index: 1; }

        .form-floating-custom .form-control {
            background: rgba(5, 7, 10, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #f0f6fc;
            border-radius: 14px;
            padding: 14px 16px 14px 48px;
            font-size: 0.95rem;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .form-floating-custom .form-control:focus {
            background: rgba(13, 17, 23, 0.95);
            border-color: #22d3ee;
            box-shadow: 0 0 0 3px rgba(34,211,238,0.15), 0 0 30px rgba(34,211,238,0.08);
            color: white;
        }

        .form-floating-custom .form-control::placeholder { color: #484f58; }

        .form-floating-custom .input-icon {
            position: absolute;
            left: 16px; top: 50%;
            transform: translateY(-50%);
            color: #22d3ee;
            font-size: 1rem;
            transition: all 0.3s ease;
            z-index: 2;
        }

        .form-floating-custom:focus-within .input-icon {
            color: #67e8f9;
            transform: translateY(-50%) scale(1.15);
            filter: drop-shadow(0 0 6px rgba(34,211,238,0.5));
        }

        .form-label {
            font-weight: 600;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #8b949e;
            margin-bottom: 8px;
        }

        .register-btn {
            background: linear-gradient(135deg, #22d3ee, #0891b2);
            border: none;
            color: #000;
            font-weight: 700;
            font-size: 1.05rem;
            padding: 14px;
            border-radius: 14px;
            position: relative;
            z-index: 1;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 4px 20px rgba(34,211,238,0.3);
        }

        .register-btn:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 30px rgba(34,211,238,0.5);
            background: linear-gradient(135deg, #67e8f9, #22d3ee);
        }

        .register-btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }
        .register-btn:hover::before { left: 100%; }

        .login-link {
            color: #22d3ee;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            position: relative;
            z-index: 1;
        }

        .login-link:hover {
            color: #67e8f9;
            text-shadow: 0 0 15px rgba(34,211,238,0.4);
        }

        .alert-custom-err {
            background: rgba(220, 53, 69, 0.12);
            border: 1px solid rgba(251, 113, 133, 0.2);
            color: #fb7185;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            z-index: 1;
        }

        @@keyframes popIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }

        .particle-field {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .particle-field span {
            position: absolute;
            width: 3px; height: 3px;
            background: rgba(34,211,238,0.3);
            border-radius: 50%;
            animation: particleUp 8s infinite linear;
        }

        .particle-field span:nth-child(2) { left: 15%; animation-delay: -2s; animation-duration: 11s; background: rgba(167,139,250,0.25); }
        .particle-field span:nth-child(3) { left: 35%; animation-delay: -4s; animation-duration: 10s; width: 2px; height: 2px; }
        .particle-field span:nth-child(4) { left: 55%; animation-delay: -1s; animation-duration: 13s; background: rgba(251,191,36,0.2); }
        .particle-field span:nth-child(5) { left: 75%; animation-delay: -3s; animation-duration: 9s; }
        .particle-field span:nth-child(6) { left: 85%; animation-delay: -5s; animation-duration: 15s; background: rgba(167,139,250,0.15); width: 2px; height: 2px; }

        @@keyframes particleUp {
            0% { top: 100%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: -5%; opacity: 0; }
        }
    </style>
</head>
<body>
    <div class="particle-field">
        <span></span><span></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="container" style="position:relative;z-index:1;">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="register-card p-4 p-md-5">
                    <div class="text-center mb-4 mt-2">
                        <div class="brand-text mb-2"><i class="fa-solid fa-user-plus"></i> Ekibe Katil</div>
                        <p class="subtitle">Gorevlerini yapay zeka ile yonetmeye basla.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert-custom-err text-center py-2 px-3 mb-3">
                            <i class="fa-solid fa-circle-exclamation me-1"></i> @ViewBag.Error
                        </div>
                    }

                    <form asp-controller="Auth" asp-action="Register" method="post">
                        <div class="mb-3">
                            <label class="form-label">Adiniz Soyadiniz</label>
                            <div class="form-floating-custom">
                                <input asp-for="FullName" class="form-control" placeholder="Enes Altindal" required>
                                <i class="fa-solid fa-user input-icon"></i>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-posta Adresi</label>
                            <div class="form-floating-custom">
                                <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" required>
                                <i class="fa-solid fa-envelope input-icon"></i>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Sifre Belirleyin</label>
                            <div class="form-floating-custom">
                                <input asp-for="Password" type="password" class="form-control" placeholder="********" required>
                                <i class="fa-solid fa-key input-icon"></i>
                            </div>
                        </div>
                        <button type="submit" class="register-btn w-100 mb-3">
                            Kayit Ol <i class="fa-solid fa-rocket ms-2"></i>
                        </button>
                    </form>

                    <div class="d-flex align-items-center mb-3">
                        <hr class="flex-grow-1 border-secondary" style="opacity:0.2;">
                        <span class="mx-2 text-muted small text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">YADA SOSYAL KAYIT</span>
                        <hr class="flex-grow-1 border-secondary" style="opacity:0.2;">
                    </div>

                    <a asp-action="GoogleLogin" class="btn btn-dark w-100 mb-4 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 12px; transition: all 0.3s ease;">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" style="width: 18px; height: 18px; margin-right: 12px;">
                        <span class="text-light">Google ile Hizli Kayit Ol</span>
                    </a>

                    <div class="text-center mt-2">
                        <a asp-action="Login" class="login-link">
                            <i class="fa-solid fa-arrow-left me-1"></i> Zaten hesabin var mi? Giris Yap
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>