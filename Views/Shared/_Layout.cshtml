<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoldBranch AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .fade-in-up {
            animation: fadeInUp 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }
        @@keyframes fadeInUp {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .gradient-text {
            background: linear-gradient(45deg, #ffc107, #ff9800);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-secondary shadow-sm mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold gradient-text" asp-controller="Task" asp-action="Index" style="font-size: 1.4rem;">
                    <i class="fa-solid fa-leaf text-warning"></i> GoldBranch AI
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item"><a class="nav-link text-light px-3" asp-controller="Task" asp-action="Index">Görev Panosu</a></li>
                        <li class="nav-item"><a class="nav-link text-info px-3 fw-bold" asp-controller="Chat" asp-action="Index"><i class="fa-solid fa-comments"></i> Ekip Chat</a></li>
                        @if (User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-warning fw-bold px-3" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-crown"></i> Admin Paneli</a>
                                <ul class="dropdown-menu dropdown-menu-dark shadow-lg">
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Users">Ekip Yönetimi</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="WorkReports">Z-Raporu</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="BurnoutMap">Isı Haritası</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Leaderboard">Performans Ligi</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="SystemLogs">Sistem Terminali</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center bg-secondary bg-opacity-25 px-3 py-1 rounded-pill border border-secondary">
                                <span class="text-light me-3 small fw-bold"><i class="fa-solid fa-user-astronaut text-warning"></i> @User.Identity.Name</span>
                                <a class="btn btn-danger btn-sm rounded-pill" asp-controller="Auth" asp-action="Logout"><i class="fa-solid fa-power-off"></i></a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container"><main role="main" class="pb-5">@RenderBody()</main></div>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            const timerElement = document.getElementById("screenTimer");
            const todayStr = new Date().toISOString().split('T')[0];
            const rawUserName = "@User.Identity.Name";
            const safeUserName = rawUserName.replace(/\s+/g, '_');
            const storageKey = "gb_time_" + safeUserName + "_" + todayStr;

            let totalSeconds = parseInt(localStorage.getItem(storageKey)) || 0;

            fetch('/TimeTracker/GetTodayTime')
                .then(response => response.json())
                .then(data => {
                    totalSeconds = Math.max(totalSeconds, data.minutes * 60);
                    setInterval(() => {
                        totalSeconds++;
                        localStorage.setItem(storageKey, totalSeconds);
                        if (timerElement) {
                            let h = Math.floor(totalSeconds / 3600), m = Math.floor((totalSeconds % 3600) / 60), s = totalSeconds % 60;
                            timerElement.innerHTML = (h > 0 ? h + ":" : "") + (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
                        }
                    }, 1000);
                });

            setInterval(() => { fetch('/TimeTracker/PingTime', { method: 'POST' }); }, 60000);
        </script>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>