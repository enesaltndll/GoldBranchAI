@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sisteme Giriş - GoldBranch AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            background: radial-gradient(circle at top left, #2b2e33, #000000);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .glass-card {
            background: rgba(33, 37, 41, 0.6);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 193, 7, 0.2);
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(255, 193, 7, 0.1);
        }

        .form-control:focus {
            background-color: #212529;
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card glass-card text-light p-4">
                    <div class="text-center mb-4 mt-2">
                        <h2 class="text-warning fw-bold mb-2"><i class="fa-solid fa-leaf"></i> GoldBranch AI</h2>
                        <p class="text-muted small">"İşinize Yapay Zeka, Sağlığınıza Altın Dal Dokunuşu."</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small text-center fw-bold border-0" style="background-color: rgba(220, 53, 69, 0.2); color: #ff6b6b;">
                            <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success py-2 small text-center fw-bold border-0" style="background-color: rgba(25, 135, 84, 0.2); color: #20c997;">
                            <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                        </div>
                    }

                    <form asp-controller="Auth" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label text-light small fw-bold text-uppercase"><i class="fa-solid fa-envelope text-warning"></i> Kurumsal E-posta</label>
                            <input type="email" name="email" class="form-control bg-dark text-light border-secondary py-2" placeholder="admin@test.com" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-light small fw-bold text-uppercase"><i class="fa-solid fa-lock text-warning"></i> Şifre</label>
                            <input type="password" name="password" class="form-control bg-dark text-light border-secondary py-2" placeholder="••••••••" required>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow text-dark fs-5" style="border-radius: 10px;">
                            Sisteme Giriş Yap <i class="fa-solid fa-arrow-right ms-1"></i>
                        </button>
                    </form>

                    <div class="mt-3 text-center">
                        <a asp-action="Register" class="text-warning small text-decoration-none border-bottom border-warning pb-1">Hesabın yok mu? Ekibe Katıl</a>
                    </div>

                    <div class="mt-4 text-center text-muted" style="font-size: 0.75rem;">
                        <i class="fa-solid fa-shield-halved text-success"></i> 256-bit Uçtan Uca Şifreli Bağlantı
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>