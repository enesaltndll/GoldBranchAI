@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sisteme Giris - GoldBranch AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #05070a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Animated gradient orbs */
        body::before {
            content: '';
            position: fixed;
            top: -30%; left: -10%;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(251,191,36,0.12), transparent 70%);
            border-radius: 50%;
            animation: orbFloat1 12s ease-in-out infinite;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -20%; right: -10%;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(34,211,238,0.08), transparent 70%);
            border-radius: 50%;
            animation: orbFloat2 15s ease-in-out infinite;
            pointer-events: none;
        }

        @@keyframes orbFloat1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(80px, 50px) scale(1.1); }
            66% { transform: translate(-40px, 80px) scale(0.95); }
        }

        @@keyframes orbFloat2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(-60px, -40px) scale(1.05); }
            66% { transform: translate(50px, -60px) scale(0.9); }
        }

        .login-card {
            background: rgba(13, 17, 23, 0.7);
            background: rgba(13, 17, 23, 0.98);
            border: 1px solid rgba(251, 191, 36, 0.12);
            border-radius: 24px;
            box-shadow:
                0 20px 60px rgba(0, 0, 0, 0.5),
                0 0 40px rgba(251, 191, 36, 0.05),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            animation: cardEnter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }

        @@keyframes cardEnter {
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(251,191,36,0.6), rgba(34,211,238,0.4), transparent);
            animation: topLineShimmer 3s ease-in-out infinite;
        }

        @@keyframes topLineShimmer {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        .login-card::after {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(from 0deg, transparent, rgba(251,191,36,0.03), transparent 30%);
            animation: rotateGlow 8s linear infinite;
            pointer-events: none;
        }

        @@keyframes rotateGlow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .brand-logo {
            font-size: 2rem;
            font-weight: 900;
            background: linear-gradient(135deg, #fbbf24, #fcd34d, #d97706);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradientMove 3s linear infinite;
            position: relative;
            z-index: 1;
        }

        @@keyframes gradientMove {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        .brand-logo i {
            -webkit-text-fill-color: #fbbf24;
            filter: drop-shadow(0 0 12px rgba(251,191,36,0.6));
            animation: leafSpin 4s ease-in-out infinite;
        }

        @@keyframes leafSpin {
            0%, 100% { transform: rotate(0deg) scale(1); filter: drop-shadow(0 0 12px rgba(251,191,36,0.6)); }
            25% { transform: rotate(-10deg) scale(1.1); filter: drop-shadow(0 0 20px rgba(251,191,36,0.9)); }
            50% { transform: rotate(5deg) scale(1.05); }
            75% { transform: rotate(-3deg) scale(0.98); }
        }

        .brand-tagline {
            font-size: 0.8rem;
            color: #8b949e;
            letter-spacing: 1px;
            position: relative;
            z-index: 1;
        }

        .form-floating-custom {
            position: relative;
            z-index: 1;
        }

        .form-floating-custom .form-control {
            background: rgba(5, 7, 10, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #f0f6fc;
            border-radius: 14px;
            padding: 14px 16px 14px 48px;
            font-size: 0.95rem;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            height: auto;
        }

        .form-floating-custom .form-control:focus {
            background: rgba(13, 17, 23, 0.95);
            border-color: #fbbf24;
            box-shadow: 0 0 0 3px rgba(251,191,36,0.15), 0 0 30px rgba(251,191,36,0.08);
            color: white;
        }

        .form-floating-custom .form-control::placeholder {
            color: #484f58;
        }

        .form-floating-custom .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #fbbf24;
            font-size: 1rem;
            transition: all 0.3s ease;
            z-index: 2;
        }

        .form-floating-custom .form-control:focus ~ .input-icon,
        .form-floating-custom:focus-within .input-icon {
            color: #fcd34d;
            transform: translateY(-50%) scale(1.15);
            filter: drop-shadow(0 0 6px rgba(251,191,36,0.5));
        }

        .form-label {
            font-weight: 600;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #8b949e;
            margin-bottom: 8px;
        }

        .login-btn {
            background: linear-gradient(135deg, #fbbf24, #d97706);
            border: none;
            color: #000;
            font-weight: 700;
            font-size: 1.05rem;
            padding: 14px;
            border-radius: 14px;
            position: relative;
            z-index: 1;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 4px 20px rgba(251,191,36,0.3);
        }

        .login-btn:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 30px rgba(251,191,36,0.5);
            background: linear-gradient(135deg, #fcd34d, #fbbf24);
        }

        .login-btn:active {
            transform: translateY(-1px) scale(0.99);
        }

        .login-btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }

        .login-btn:hover::before { left: 100%; }

        .register-link {
            color: #fbbf24;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            position: relative;
            z-index: 1;
        }

        .register-link:hover {
            color: #fcd34d;
            text-shadow: 0 0 15px rgba(251,191,36,0.4);
        }

        .security-badge {
            font-size: 0.7rem;
            color: #484f58;
            position: relative;
            z-index: 1;
        }

        .security-badge i { color: #34d399; }

        .alert-custom-danger {
            background: rgba(220, 53, 69, 0.12);
            border: 1px solid rgba(251, 113, 133, 0.2);
            color: #fb7185;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            animation: alertPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            z-index: 1;
        }

        .alert-custom-success {
            background: rgba(52, 211, 153, 0.12);
            border: 1px solid rgba(52, 211, 153, 0.2);
            color: #34d399;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            animation: alertPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            z-index: 1;
        }

        @@keyframes alertPop {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        /* Floating particles for login page */
        .particle-field {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .particle-field span {
            position: absolute;
            width: 3px; height: 3px;
            background: rgba(251,191,36,0.3);
            border-radius: 50%;
            animation: particleDrift 8s infinite linear;
        }

        .particle-field span:nth-child(2) { left: 20%; animation-delay: -2s; animation-duration: 12s; background: rgba(34,211,238,0.2); }
        .particle-field span:nth-child(3) { left: 40%; animation-delay: -4s; animation-duration: 10s; width: 2px; height: 2px; }
        .particle-field span:nth-child(4) { left: 60%; animation-delay: -1s; animation-duration: 14s; background: rgba(167,139,250,0.2); }
        .particle-field span:nth-child(5) { left: 80%; animation-delay: -3s; animation-duration: 9s; }
        .particle-field span:nth-child(6) { left: 10%; animation-delay: -5s; animation-duration: 11s; background: rgba(34,211,238,0.15); }
        .particle-field span:nth-child(7) { left: 70%; animation-delay: -6s; animation-duration: 13s; width: 2px; height: 2px; }
        .particle-field span:nth-child(8) { left: 90%; animation-delay: -2.5s; animation-duration: 16s; background: rgba(251,191,36,0.15); }

        @@keyframes particleDrift {
            0% { top: 100%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: -5%; opacity: 0; }
        }
    </style>
</head>
<body>
    <!-- Floating Particles -->
    <div class="particle-field">
        <span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span>
    </div>

    <div class="container" style="position:relative;z-index:1;">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="login-card p-4 p-md-5">
                    <div class="text-center mb-4 mt-2">
                        <div class="brand-logo mb-2"><i class="fa-solid fa-leaf"></i> GoldBranch AI</div>
                        <p class="brand-tagline">"Isinize Yapay Zeka, Sagliginiza Altin Dal Dokunusu."</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert-custom-danger text-center py-2 px-3 mb-3">
                            <i class="fa-solid fa-circle-exclamation me-1"></i> @ViewBag.Error
                        </div>
                    }
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert-custom-success text-center py-2 px-3 mb-3">
                            <i class="fa-solid fa-check-circle me-1"></i> @TempData["Success"]
                        </div>
                    }

                    <form asp-controller="Auth" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label"><i class="fa-solid fa-envelope text-warning me-1"></i> Kurumsal E-posta</label>
                            <div class="form-floating-custom">
                                <input type="email" name="email" class="form-control" placeholder="admin@test.com" required autocomplete="email">
                                <i class="fa-solid fa-at input-icon"></i>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label"><i class="fa-solid fa-lock text-warning me-1"></i> Sifre</label>
                            <div class="form-floating-custom">
                                <input type="password" name="password" class="form-control" placeholder="********" required>
                                <i class="fa-solid fa-shield-halved input-icon"></i>
                            </div>
                        </div>
                        <button type="submit" class="login-btn w-100 mb-3">
                            Sisteme Giris Yap <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <div class="d-flex align-items-center mb-3">
                        <hr class="flex-grow-1 border-secondary" style="opacity:0.2;">
                        <span class="mx-2 text-muted small text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">YADA SOSYAL GIRIS</span>
                        <hr class="flex-grow-1 border-secondary" style="opacity:0.2;">
                    </div>

                    <a asp-action="GoogleLogin" class="btn btn-dark w-100 mb-4 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 12px; transition: all 0.3s ease;">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google Logo" style="width: 18px; height: 18px; margin-right: 12px;">
                        <span class="text-light">Google ile Guvenli Giris</span>
                    </a>

                    <div class="text-center mt-2">
                        <a asp-action="Register" class="register-link">
                            <i class="fa-solid fa-user-plus me-1"></i> Hesabin yok mu? Ekibe Katil
                        </a>
                    </div>

                    <div class="mt-4 text-center security-badge">
                        <i class="fa-solid fa-shield-halved me-1"></i> 256-bit Uctan Uca Sifreli Baglanti
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>