@{
    ViewData["Title"] = "Burnout Isı Haritası";
}

<div class="row mb-4 align-items-center fade-in-up">
    <div class="col-md-8">
        <h2 class="text-light fw-bold mb-0"><i class="fa-solid fa-fire-flame-curved text-danger"></i> Tükenmişlik (Burnout) Radarı</h2>
        <p class="text-muted">Ekibinizin bu haftaki aktif ekran sürelerine göre stres ve yorgunluk analizleri.</p>
    </div>
</div>

<div class="card bg-dark border-0 shadow-lg fade-in-up" style="border-radius: 15px; border-top: 4px solid #dc3545;">
    <div class="card-body p-4">
        @foreach (Tuple<GoldBranchAI.Models.AppUser, int> item in ViewBag.BurnoutData)
        {
            var user = item.Item1;
            var totalMinutes = item.Item2;

            int percent = (int)Math.Round((double)totalMinutes / 2400 * 100);
            if (percent > 100) percent = 100;

            string barColor = percent > 80 ? "bg-danger progress-bar-striped progress-bar-animated" :
            (percent > 50 ? "bg-warning" : "bg-success");
            string statusIcon = percent > 80 ? "<i class='fa-solid fa-skull-crossbones text-danger'></i> Kritik" :
            (percent > 50 ? "<i class='fa-solid fa-battery-half text-warning'></i> Yorgun" : "<i class='fa-solid fa-battery-full text-success'></i> Dinç");

            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1">
                    <span class="fw-bold text-light">@user.FullName <span class="badge bg-secondary ms-2">@user.Role</span></span>
                    <span class="small fw-bold">@Html.Raw(statusIcon) (@(totalMinutes / 60) Saat)</span>
                </div>
                <div class="progress bg-secondary bg-opacity-50" style="height: 15px; border-radius: 10px;">
                    <div class="progress-bar @barColor" role="progressbar" style="width: @percent%; box-shadow: 0 0 10px rgba(0,0,0,0.5);"></div>
                </div>
            </div>
        }

        @if (((List<Tuple<GoldBranchAI.Models.AppUser, int>>)ViewBag.BurnoutData).Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="fa-solid fa-bed fa-3x mb-3 opacity-50"></i><br />
                Bu haftaya ait henüz hiçbir çalışma/mesai verisi bulunmuyor.
            </div>
        }
    </div>
</div>